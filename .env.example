# Rede padrao do Hardhat: hardhat ou sepolia
REPAIRDAO_DEFAULT_NETWORK=hardhat

# RPC local usado em deploy e integracao com a rede local
HARDHAT_RPC_URL=http://127.0.0.1:8545
HARDHAT_PRICE_FEED_INITIAL_PRICE=200000000000
HARDHAT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC publica validada para Sepolia; substitua se preferir usar um provedor com chave propria
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_PRICE_FEED_ADDRESS=0x694AA1769357215DE4FAC081bf1f309aDC325306
# Chave privada para deploy e interacao com a rede Sepolia; substitua por sua chave privada
SEPOLIA_PRIVATE_KEY=

# Configuracoes publicas opcionais para auditoria Mythril via Docker
MYTHRIL_EXECUTION_TIMEOUT=20
MYTHRIL_SOLC_VERSION=0.8.25
